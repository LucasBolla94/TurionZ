# ============================================================
# TurionZ (Thor) — Environment Variables
# Created by BollaNetwork
# ============================================================

# --- Anthropic (Main Brain — Thor uses Claude Opus 4.6 directly) ---
ANTHROPIC_API_KEY=sk-ant-...
MAIN_MODEL=claude-opus-4-6

# --- OpenRouter (Sub-agents — model variety and cost optimization) ---
OPENROUTER_API_KEY=sk-or-...
SUB_AGENT_DEFAULT_MODEL=google/gemini-2.5-flash-preview
ANALYSIS_MODEL=google/gemini-2.5-flash-preview

# --- Telegram ---
TELEGRAM_BOT_TOKEN=...

# --- Discord (optional) ---
DISCORD_BOT_TOKEN=...

# --- API REST (optional) ---
API_PORT=3000
API_ACCESS_KEY=...

# --- PostgreSQL ---
DATABASE_URL=postgresql://user:pass@localhost:5432/turionz

# --- Agent Config ---
MAX_ITERATIONS=5
CONTEXT_WINDOW_SIZE=150000

# --- Owner ---
OWNER_TELEGRAM_ID=123456789
OWNER_NAME=Lucas
OWNER_DISCORD_ID=...
OWNER_WHATSAPP_ID=...
